# ════════════════════════════════════════════
# KarAmoozYar — Root Environment Variables
# Docker Compose services
# ════════════════════════════════════════════
# Copy this file to .env and fill in the values

# ─── PostgreSQL ──────────────────────────────
POSTGRES_DB=karamooziyar
POSTGRES_USER=karamooz_user
POSTGRES_PASSWORD=karamooz_pass_CHANGE_IN_PROD
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_CHANGE_IN_PROD

# ─── MinIO ───────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret_CHANGE_IN_PROD
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=karamooziyar
