# ════════════════════════════════════════════════════════════════
# KarAmoozYar — Caddy reverse proxy
# این فایل را روی سرور در مسیر  C:\Caddy\Caddyfile  بگذار
# Caddy خودش گواهی HTTPS (Let's Encrypt) را می‌گیرد و تمدید می‌کند.
# ════════════════════════════════════════════════════════════════

# ─── دامنه‌ی اصلی اپلیکیشن ───────────────────────────────────────
yar.mkrm.ir {

	# فشرده‌سازی پاسخ‌ها (سرعت بیشتر)
	encode zstd gzip

	# ① API (همه‌ی مسیرهای REST زیر /api/v1)
	handle /api/* {
		reverse_proxy 127.0.0.1:9101
	}

	# ② فایل‌های آپلودشده: تصویر / ویس / فایل  →  https://yar.mkrm.ir/files/<key>
	handle /files/* {
		reverse_proxy 127.0.0.1:9101
	}

	# ③ ریل‌تایم (Socket.IO / WebSocket). Caddy خودش ارتقای WebSocket را مدیریت می‌کند.
	handle /socket.io/* {
		reverse_proxy 127.0.0.1:9101
	}

	# ④ بقیه‌ی مسیرها  →  اپ Next.js
	handle {
		reverse_proxy 127.0.0.1:9100
	}
}

# ─── دامنه‌ی دوم (pwa) ───────────────────────────────────────────
# اگر می‌خواهی pwa.mkrm.ir هم از همین Caddy رد شود، خط‌های زیر را از حالت
# کامنت دربیاور و عددِ پورت را با پورتی که اپ pwa روی آن بالاست عوض کن.
# اگر pwa با سرویس دیگری (مثلاً IIS) بالا می‌آید، این بخش را دست نزن و
# بخش «حالت B» در راهنما را بخوان.
#
# pwa.mkrm.ir {
# 	encode zstd gzip
# 	reverse_proxy 127.0.0.1:PORT_PWA
# }
