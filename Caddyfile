# ════════════════════════════════════════════════════════════════
# KarAmoozYar — Caddy به‌عنوان ORIGIN پشت آروان‌کلاد (ArvanCloud)
# ────────────────────────────────────────────────────────────────
# دامنه پشت آروان‌کلاد است و خودِ آروان HTTPS را می‌دهد. این سرور فقط origin است
# و Caddy اینجا یک reverse proxy ساده روی پورت 80 است (SSL لازم ندارد).
#
# جریان: کاربر → HTTPS → آروان‌کلاد → HTTP پورت 80 → این Caddy → اپ‌های 9100/9101
#
# این فایل را روی سرور در مسیر  C:\Caddy\Caddyfile  بگذار و سرویس را restart کن:
#   nssm restart Caddy
# ════════════════════════════════════════════════════════════════

{
	# SSL خودکار خاموش — TLS را آروان‌کلاد در لبه انجام می‌دهد، نه این سرور.
	auto_https off
}

:80 {
	encode zstd gzip

	# ① API (REST زیر /api/v1)
	handle /api/* {
		reverse_proxy 127.0.0.1:9101
	}

	# ② فایل‌های آپلودشده (تصویر/ویس/فایل) → /files/<key>
	handle /files/* {
		reverse_proxy 127.0.0.1:9101
	}

	# ③ ریل‌تایم (Socket.IO / WebSocket)
	handle /socket.io/* {
		reverse_proxy 127.0.0.1:9101
	}

	# ④ دارایی‌های ثابتِ Next (هش‌دار و immutable) — کش بماند (سریع‌تر)
	handle /_next/static/* {
		reverse_proxy 127.0.0.1:9100
	}

	# ⑤ فایلِ نسخه — هرگز کش نشود (کلاینت با آن آپدیت را تشخیص می‌دهد)
	handle /version.json {
		reverse_proxy 127.0.0.1:9100 {
			header_down Cache-Control "no-store, must-revalidate"
		}
	}

	# ⑥ سرویس‌ورکر — کش نشود تا آپدیتِ SW فوری دیده شود
	handle /sw.js {
		reverse_proxy 127.0.0.1:9100 {
			header_down Cache-Control "no-cache, must-revalidate"
		}
	}

	# ⑦ بقیه‌ی مسیرها (صفحاتِ HTML) → اپ Next.js
	#    Cache-Control را به no-cache override می‌کنیم تا آروان/مرورگر صفحهٔ HTML
	#    را برای همیشه کش نکنند و build جدید بلافاصله دیده شود.
	handle {
		reverse_proxy 127.0.0.1:9100 {
			header_down Cache-Control "no-cache, no-store, must-revalidate"
		}
	}
}
