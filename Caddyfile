# ════════════════════════════════════════════════════════════════
# KarAmoozYar — Caddy به‌عنوان ORIGIN پشت آروان‌کلاد (ArvanCloud)
# ────────────────────────────────────────────────────────────────
# دامنه‌ی yar.mkrm.ir پشت آروان‌کلاد است و *خودِ آروان* HTTPS را می‌دهد.
# پس این سرور فقط «origin» است و Caddy اینجا فقط یک reverse proxy ساده
# روی پورت 80 است — به SSL/Let's Encrypt روی این سرور نیازی نیست.
#
# جریان: کاربر → HTTPS → آروان‌کلاد → HTTP پورت 80 → این Caddy → اپ‌های 9100/9101
#
# این فایل را روی سرور در مسیر  C:\Caddy\Caddyfile  بگذار.
# ════════════════════════════════════════════════════════════════

{
	# SSL خودکار خاموش — چون TLS را آروان‌کلاد در لبه انجام می‌دهد، نه این سرور.
	# اگر این را خاموش نکنیم، Caddy می‌خواهد گواهی بگیرد و چون دامنه به آروان اشاره
	# می‌کند نه به سرور، گرفتن گواهی شکست می‌خورد.
	auto_https off
}

# روی پورت 80 گوش بده و هر چیزی که از آروان می‌آید را پراکسی کن.
:80 {
	encode zstd gzip

	# ① API (همه‌ی مسیرهای REST زیر /api/v1)
	handle /api/* {
		reverse_proxy 127.0.0.1:9101
	}

	# ② فایل‌های آپلودشده: تصویر / ویس / فایل  →  /files/<key>
	handle /files/* {
		reverse_proxy 127.0.0.1:9101
	}

	# ③ ریل‌تایم (Socket.IO / WebSocket)
	handle /socket.io/* {
		reverse_proxy 127.0.0.1:9101
	}

	# ④ بقیه‌ی مسیرها  →  اپ Next.js
	handle {
		reverse_proxy 127.0.0.1:9100
	}
}

# ════════════════════════════════════════════════════════════════
# نکته‌ی مهم: این Caddy «هیچ ریدایرکتی» نمی‌زند و فقط محتوا را برمی‌گرداند.
# همین باعث می‌شود آن پرشِ زشت به http://185.255.88.13:9100 از بین برود،
# چون قبلاً پورت 80 سرور به آن آدرس ریدایرکت می‌داد.
# ════════════════════════════════════════════════════════════════
