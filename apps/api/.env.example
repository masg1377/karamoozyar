# ════════════════════════════════════════════
# KarAmoozYar API — Environment Variables
# Copy to .env and fill in values
# ════════════════════════════════════════════

# ─── App ─────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# ─── Database ────────────────────────────────
DATABASE_URL=postgresql://karamooz_user:karamooz_pass_CHANGE_IN_PROD@localhost:5432/karamooziyar

# ─── Redis ───────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_CHANGE_IN_PROD

# ─── JWT ─────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_THIS_TO_RANDOM_32+_CHARS_ACCESS
JWT_REFRESH_SECRET=CHANGE_THIS_TO_RANDOM_32+_CHARS_REFRESH
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=90d

# ─── S3 / MinIO ──────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_secret_CHANGE_IN_PROD
S3_BUCKET_NAME=karamooziyar
S3_REGION=us-east-1
S3_USE_SSL=false
# For production AWS S3, set S3_USE_SSL=true and remove S3_ENDPOINT

# ─── File Upload ─────────────────────────────
MAX_FILE_SIZE_BYTES=15728640
# 15728640 = 15 * 1024 * 1024 (15 MB)

# ─── OTP (Simulated for MVP) ─────────────────
OTP_EXPIRY_SECONDS=120
OTP_LENGTH=6
# OTP_FIXED_CODE=123456  # Only for dev — force a fixed OTP

# ─── SMS Provider (PishgamRayan) ──────────────
# Development: leave blank — OTP printed to console, no real SMS sent
# Production:  fill in the values from PishgamRayan panel
MESSAGE_PROVIDER_API_KEY=THw8XUJRUiiH7bGmRqT6ybVaQM4v5lTOmSHZxCiLAHc=
MESSAGE_PROVIDER_SENDER_NUMBER=50003975
MESSAGE_PROVIDER_OTP_TEMPLATE_ID=100393

# ─── Rate Limiting ───────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─── CORS ────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Frontend URL ────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Web Push (VAPID — self-hosted, no third-party) ─────────
# Generate fresh keys per environment:
# node -e "const c=require('crypto');const{publicKey,privateKey}=c.generateKeyPairSync('ec',{namedCurve:'prime256v1'});const p=publicKey.export({format:'jwk'});console.log('VAPID_PUBLIC_KEY='+Buffer.concat([Buffer.from([4]),Buffer.from(p.x,'base64url'),Buffer.from(p.y,'base64url')]).toString('base64url'));console.log('VAPID_PRIVATE_KEY='+privateKey.export({format:'jwk'}).d)"
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME
VAPID_SUBJECT=mailto:admin@karamooziyar.ir
